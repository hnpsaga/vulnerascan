{
  "name": "@hnpsaga/vulnerascan",
  "version": "0.0.3",
  "description": "Developer-first vulnerability scanner for modern software projects.",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "vulnerascan": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "licenses:check": "license-checker-rseidelsohn --production --onlyAllow \"MIT;ISC;BSD-2-Clause;BSD-3-Clause;Apache-2.0;0BSD;CC0-1.0\""
  },
  "keywords": [
    "security",
    "vulnerability-scanner",
    "dependency-analysis",
    "dependency-graph",
    "typescript",
    "cli",
    "developer-tools",
    "osv",
    "supply-chain-security",
    "open-source-security"
  ],
  "author": {
    "name": "Hari Naga Praveen Saga",
    "url": "https://github.com/hnpsaga"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hnpsaga/vulnerascan.git"
  },
  "homepage": "https://github.com/hnpsaga/vulnerascan#readme",
  "bugs": {
    "url": "https://github.com/hnpsaga/vulnerascan/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "dependencies": {
    "@yarnpkg/lockfile": "^1.1.0",
    "commander": "^14.0.0",
    "smol-toml": "^1.7.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^26.0.0",
    "@types/yarnpkg__lockfile": "^1.1.9",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.0.0",
    "license-checker-rseidelsohn": "^5.0.1",
    "prettier": "^3.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  }
}
